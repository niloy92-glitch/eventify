# Eventify Environment Configuration Template
# Copy this to .env and fill in your actual values

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# DEBUG MODE: Set to False for production!
# In production, set to False to disable debug info leaking to users
DEBUG=True

# SECRET KEY: CHANGE THIS IN PRODUCTION!
# Generate a new key: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-your-secret-key-change-in-production

# ALLOWED HOSTS: Which domains this app serves
# For production, set to your actual domain(s)
# Format: comma-separated list (e.g., "example.com,www.example.com")
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Choose ONE of these options:

# OPTION 1: SQLite (local development, simplest)
USE_SQLITE=1

# OPTION 2: PostgreSQL (production recommended)
# Uncomment and configure below, set USE_SQLITE=0
## DATABASE_URL=postgresql://postgres:password@localhost:5432/eventify_db
## POSTGRES_CONN_MAX_AGE=600
## POSTGRES_SSLMODE=prefer

# Individual database settings (used if DATABASE_URL not set):
## DB_NAME=eventify_db
## DB_USER=postgres
## DB_PASSWORD=your_db_password
## DB_HOST=localhost
## DB_PORT=5432

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Required for user registration (email verification) and password reset

# Gmail Configuration Example:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# Use Gmail "App Passwords" if 2FA enabled (not your regular Gmail password)
EMAIL_HOST_PASSWORD=your-app-password-16-chars

# Sender info
SENDER_ADDRESS=your-email@gmail.com
SENDER_NAME=Eventify

# ============================================================================
# EMAIL BRANDING
# ============================================================================
# Colors used in email templates (hex format)

EMAIL_BRAND_NAME=Eventify
EMAIL_BRAND_PRIMARY=#f97316          # Orange
EMAIL_BRAND_SECONDARY=#10b981        # Green
EMAIL_BRAND_BG=#fff7ed               # Light orange background
EMAIL_BRAND_CARD=#ffffff             # White card
EMAIL_BRAND_TEXT=#1f2937             # Dark text
EMAIL_BRAND_MUTED=#6b7280            # Gray text

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Require email verification on registration
REQUIRE_EMAIL_VERIFICATION=True

# ============================================================================
# OAUTH (Optional - for future Google/social login)
# ============================================================================

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================================
# PRODUCTION SECURITY SETTINGS
# ============================================================================
# Only apply when DEBUG=False

# Enable HTTPS redirect (set to True in production)
SECURE_SSL_REDIRECT=False

# Secure session cookie (set to True in production with HTTPS)
SESSION_COOKIE_SECURE=False

# Secure CSRF cookie (set to True in production with HTTPS)
CSRF_COOKIE_SECURE=False

# HSTS: Force HTTPS for specified seconds (1 year = 31536000)
SECURE_HSTS_SECONDS=0

# Include subdomains in HSTS
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# HSTS Preload (for HSTS preload list)
SECURE_HSTS_PRELOAD=False

# SameSite cookie policy
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# HTTP X-Frame-Options header (prevent clickjacking)
X_FRAME_OPTIONS=DENY

# ============================================================================
# NOTES
# ============================================================================
# 
# Gmail Setup Instructions:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an "App Password" at https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password and paste into EMAIL_HOST_PASSWORD
# 4. Use your regular Gmail address in EMAIL_HOST_USER
#
# PostgreSQL Setup Instructions:
# 1. Install PostgreSQL locally or use a hosted service
# 2. Create database: createdb eventify_db
# 3. Create user: createuser postgres (or configure user/password)
# 4. Grant privileges: psql -U postgres -c "ALTER ROLE postgres PASSWORD 'password'"
# 5. Set DATABASE_URL=postgresql://postgres:password@localhost:5432/eventify_db
#
# Production Deployment:
# 1. Set DEBUG=False
# 2. Set ALLOWED_HOSTS to your actual domain(s)
# 3. Use PostgreSQL (not SQLite)
# 4. Generate new DJANGO_SECRET_KEY
# 5. Enable all SECURE_* settings
# 6. Use environment variables or secrets management (not in .env file)
#
